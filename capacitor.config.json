
{
  "appId": "com.smileprox.app",
  "appName": "SmileProX",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "allowNavigation": ["*"],
    "cleartext": true
  },
  "plugins": {
    "Haptics": {
      "enabled": true
    },
    "StatusBar": {
      "overlaysWebView": true,
      "style": "DARK"
    },
    "Camera": {
      "presentationStyle": "fullscreen"
    },
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0f172a",
      "showSpinner": true,
      "androidScaleType": "CENTER_CROP"
    }
  }
}
