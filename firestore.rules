rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    
    function getUserData() {
      return userExists() ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data : null;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "leooliveira0630@gmail.com" && request.auth.token.email_verified == true) ||
        (userExists() && getUserData().get('role', null) == 'SUPER_ADMIN')
      );
    }
    
    function hasPermission(perm) {
      return isAuthenticated() && userExists() && getUserData().get('permissions', []).hasAny([perm]);
    }
    
    function isAdmin() {
      return isAuthenticated() && userExists() && (getUserData().get('role', null) == 'ADMIN' || getUserData().get('role', null) == 'SUPER_ADMIN');
    }
    
    function isManager() {
      return isAuthenticated() && userExists() && (getUserData().get('role', null) == 'MANAGER' || getUserData().get('role', null) == 'ADMIN' || getUserData().get('role', null) == 'SUPER_ADMIN');
    }

    function belongsToOrg(orgId) {
      return isAuthenticated() && userExists() && getUserData().get('organizationId', null) == orgId;
    }

    match /users/{userId} {
      // Allow reading own profile, or if super admin, or if manager in same org
      allow read: if isAuthenticated() && (
        request.auth.uid == userId || 
        isSuperAdmin() ||
        (userExists() && getUserData().get('organizationId', null) == resource.data.get('organizationId', null) && isManager())
      );
      
      // Allow creating own profile or admin creating users
      allow create: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      // Allow updating own profile or admin updating users
      allow update: if isAuthenticated() && (
        request.auth.uid == userId || 
        isSuperAdmin() ||
        (userExists() && getUserData().get('organizationId', null) == resource.data.get('organizationId', null) && isAdmin())
      );
      
      allow delete: if isSuperAdmin() || (userExists() && getUserData().get('organizationId', null) == resource.data.get('organizationId', null) && (isAdmin() || hasPermission('users:manage')));
    }
    
    match /organizations/{orgId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin() || (belongsToOrg(orgId) && isAdmin());
      
      match /jobs/{jobId} {
        allow read: if isAuthenticated() && (
          isSuperAdmin() || 
          belongsToOrg(orgId) ||
          (getUserData().get('role', null) == 'CLIENT' && resource.data.get('dentistId', null) == request.auth.uid)
        );
        allow create: if isAuthenticated() && (
          isSuperAdmin() || 
          belongsToOrg(orgId) ||
          (getUserData().get('role', null) == 'CLIENT' && request.resource.data.get('dentistId', null) == request.auth.uid)
        );
        allow update: if isAuthenticated() && (
          isSuperAdmin() || 
          belongsToOrg(orgId) ||
          (getUserData().get('role', null) == 'CLIENT' && resource.data.get('dentistId', null) == request.auth.uid && request.resource.data.get('dentistId', null) == request.auth.uid)
        );
        allow delete: if isAuthenticated() && (
          isSuperAdmin() || 
          belongsToOrg(orgId)
        );
      }

      match /jobTypes/{jobTypeId} {
        allow read: if isAuthenticated() && (
          isSuperAdmin() || 
          belongsToOrg(orgId) ||
          (userExists() && getUserData().get('role', null) == 'CLIENT')
        );
        allow write: if isAuthenticated() && (
          isSuperAdmin() || 
          (belongsToOrg(orgId) && isAdmin())
        );
      }

      match /{allSubcollections=**} {
        allow read: if isAuthenticated() && (isSuperAdmin() || belongsToOrg(orgId));
        allow write: if isAuthenticated() && (isSuperAdmin() || belongsToOrg(orgId));
      }
    }
    
    match /settings/global {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    match /coupons/{couponId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }
  }
}
