rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "leooliveira0630@gmail.com") ||
        (request.auth.uid == "Ma8AYRpvAIRAydfQ7D93pI30zsQ2") ||
        (userExists() && getUserData().get('role', 'USER') == 'SUPER_ADMIN')
      );
    }
    
    function hasPermission(perm) {
      return isAuthenticated() && userExists() && getUserData().get('permissions', []).hasAny([perm]);
    }
    
    function isAdmin() {
      return isAuthenticated() && userExists() && (getUserData().get('role', 'USER') == 'ADMIN' || getUserData().get('role', 'USER') == 'SUPER_ADMIN');
    }
    
    function isManager() {
      return isAuthenticated() && userExists() && (getUserData().get('role', 'USER') == 'MANAGER' || getUserData().get('role', 'USER') == 'ADMIN' || getUserData().get('role', 'USER') == 'SUPER_ADMIN');
    }

    function belongsToOrg(orgId) {
      return isAuthenticated() && userExists() && getUserData().get('organizationId', '') == orgId;
    }

    match /organizations/{orgId}/inventoryCategories/{categoryId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || belongsToOrg(orgId));
      allow write: if isAuthenticated() && (isSuperAdmin() || belongsToOrg(orgId));
    }
    match /organizations/{orgId}/inventoryItems/{itemId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || belongsToOrg(orgId));
      allow write: if isAuthenticated() && (isSuperAdmin() || belongsToOrg(orgId));
    }
    
    match /users/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId || 
        isSuperAdmin() ||
        (userExists() && getUserData().get('organizationId', '') == resource.data.get('organizationId', ''))
      );
      
      allow create: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      allow update: if isAuthenticated() && (
        request.auth.uid == userId || 
        isSuperAdmin() ||
        (userExists() && getUserData().get('organizationId', '') == resource.data.get('organizationId', '') && isAdmin())
      );
      
      allow delete: if isSuperAdmin() || (userExists() && getUserData().get('organizationId', '') == resource.data.get('organizationId', '') && (isAdmin() || hasPermission('users:manage')));
    }
    
    match /organizations/{orgId} {
      allow read: if isAuthenticated() || (resource != null && resource.data.orgType == 'LAB');
      allow write: if isSuperAdmin() || (belongsToOrg(orgId) && (isAdmin() || getUserData().get('role', 'USER') == 'CLIENT'));
      
      match /jobs/{jobId} {
        allow read: if isAuthenticated() && (
          isSuperAdmin() || 
          (belongsToOrg(orgId) && getUserData().get('role', 'USER') != 'CLIENT') ||
          (getUserData().get('role', 'USER') == 'CLIENT' && resource.data.get('dentistId', '') == request.auth.uid)
        );
        allow create: if isAuthenticated() && (
          isSuperAdmin() || 
          (belongsToOrg(orgId) && getUserData().get('role', 'USER') != 'CLIENT') ||
          (getUserData().get('role', 'USER') == 'CLIENT' && request.resource.data.get('dentistId', '') == request.auth.uid)
        );
        allow update: if isAuthenticated() && (
          isSuperAdmin() || 
          (belongsToOrg(orgId) && getUserData().get('role', 'USER') != 'CLIENT') ||
          (getUserData().get('role', 'USER') == 'CLIENT' && resource.data.get('dentistId', '') == request.auth.uid && request.resource.data.get('dentistId', '') == request.auth.uid)
        );
        allow delete: if isAuthenticated() && (
          isSuperAdmin() || 
          (belongsToOrg(orgId) && getUserData().get('role', 'USER') != 'CLIENT')
        );
      }

      match /commissions/{commId} {
        allow read: if isAuthenticated() && (isSuperAdmin() || (belongsToOrg(orgId) && getUserData().get('role', 'USER') != 'CLIENT'));
        allow write: if isAuthenticated() && (isSuperAdmin() || (belongsToOrg(orgId) && getUserData().get('role', 'USER') != 'CLIENT'));
      }

      match /jobTypes/{jobTypeId} {
        allow read: if true;
        allow write: if isAuthenticated() && (
          isSuperAdmin() || 
          (belongsToOrg(orgId) && isAdmin())
        );
      }

      match /ratings/{ratingId} {
        allow read: if true;
        allow write: if isAuthenticated() && (
          isSuperAdmin() || 
          belongsToOrg(orgId) ||
          (userExists() && getUserData().get('role', 'USER') == 'CLIENT')
        );
      }

      match /jobs/{jobId}/messages/{messageId} {
        allow read: if isAuthenticated() && (
          isSuperAdmin() || 
          (belongsToOrg(orgId) && getUserData().get('role', 'USER') != 'CLIENT') ||
          (getUserData().get('role', 'USER') == 'CLIENT' && get(/databases/$(database)/documents/organizations/$(orgId)/jobs/$(jobId)).data.dentistId == request.auth.uid)
        );
        allow write: if isAuthenticated() && (
          isSuperAdmin() || 
          (belongsToOrg(orgId) && getUserData().get('role', 'USER') != 'CLIENT') ||
          (getUserData().get('role', 'USER') == 'CLIENT' && get(/databases/$(database)/documents/organizations/$(orgId)/jobs/$(jobId)).data.dentistId == request.auth.uid)
        );
      }

      match /connections/{connId} {
        allow read: if isAuthenticated() && (isSuperAdmin() || belongsToOrg(orgId));
        allow write: if isAuthenticated() && (
          isSuperAdmin() || 
          belongsToOrg(orgId) ||
          (userExists() && getUserData().get('organizationId', '') == request.resource.data.get('organizationId', ''))
        );
      }

      match /{allSubcollections=**} {
        allow read: if isAuthenticated() && (isSuperAdmin() || (belongsToOrg(orgId) && (getUserData().get('role', 'USER') != 'CLIENT' || get(/databases/$(database)/documents/organizations/$(orgId)).data.orgType == 'CLINIC')));
        allow write: if isAuthenticated() && (isSuperAdmin() || (belongsToOrg(orgId) && (getUserData().get('role', 'USER') != 'CLIENT' || get(/databases/$(database)/documents/organizations/$(orgId)).data.orgType == 'CLINIC')));
      }
    }
    
    match /settings/global {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    match /coupons/{couponId} {
      allow read: if isAuthenticated();
      allow create, delete: if isSuperAdmin();
      allow update: if isSuperAdmin() || (
        isAuthenticated() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usedCount']) &&
        request.resource.data.usedCount == resource.data.usedCount + 1
      );
    }

    match /subscriptionPlans/{planId} {
      allow read: if true; // Allow public reading for registration
      allow write: if isSuperAdmin();
    }

    match /tutorials/{tutorialId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || belongsToOrg(resource.data.organizationId));
      allow write: if isSuperAdmin();
    }

    match /receipts/{receiptId} {
      function isValidReceipt(data) {
        return data.keys().hasAll(['organizationId', 'numero', 'clienteName', 'valorLiquido', 'referente', 'createdBy', 'createdAt', 'dtEmissao']) &&
               data.organizationId is string &&
               data.createdBy == request.auth.uid;
      }
      
      allow read: if isAuthenticated() && (isSuperAdmin() || (belongsToOrg(resource.data.organizationId) && (isAdmin() || hasPermission('receipts:view') || hasPermission('receipts:manage') || hasPermission('receipts:create') || hasPermission('receipts:edit'))));
      
      allow create: if isAuthenticated() && (
        isSuperAdmin() || 
        (belongsToOrg(request.resource.data.organizationId) && (isAdmin() || hasPermission('receipts:manage') || hasPermission('receipts:create')) && isValidReceipt(request.resource.data))
      );
      
      allow update: if isAuthenticated() && (
        isSuperAdmin() || 
        (belongsToOrg(resource.data.organizationId) && 
         (isAdmin() || hasPermission('receipts:manage') || hasPermission('receipts:edit')) && 
         (request.resource.data.organizationId == resource.data.organizationId) &&
         isValidReceipt(request.resource.data) &&
         request.resource.data.createdBy == resource.data.createdBy)
      );
      
      allow delete: if isAuthenticated() && (isSuperAdmin() || (belongsToOrg(resource.data.organizationId) && (isAdmin() || hasPermission('receipts:manage') || hasPermission('receipts:delete'))));
    }
  }
}
