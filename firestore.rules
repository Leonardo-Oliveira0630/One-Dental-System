rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && (
        getUserData().role == 'SUPER_ADMIN' || 
        (request.auth.token.email == "leooliveira0630@gmail.com" && request.auth.token.email_verified == true)
      );
    }
    
    function isAdmin() {
      let role = getUserData().role;
      return isAuthenticated() && (role == 'ADMIN' || role == 'SUPER_ADMIN');
    }
    
    function isManager() {
      let role = getUserData().role;
      return isAuthenticated() && (role == 'MANAGER' || role == 'ADMIN' || role == 'SUPER_ADMIN');
    }

    function belongsToOrg(orgId) {
      return isAuthenticated() && getUserData().organizationId == orgId;
    }

    match /users/{userId} {
      // Allow reading own profile, or if super admin, or if manager in same org
      allow read: if isAuthenticated() && (
        request.auth.uid == userId || 
        isSuperAdmin() ||
        (getUserData().organizationId == resource.data.organizationId && isManager())
      );
      
      // Allow creating own profile or admin creating users
      allow create: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      // Allow updating own profile or admin updating users
      allow update: if isAuthenticated() && (
        request.auth.uid == userId || 
        isSuperAdmin() ||
        (getUserData().organizationId == resource.data.organizationId && isAdmin())
      );
      
      allow delete: if isSuperAdmin();
    }
    
    match /organizations/{orgId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || belongsToOrg(orgId));
      allow write: if isSuperAdmin() || (belongsToOrg(orgId) && isAdmin());
      
      match /{allSubcollections=**} {
        allow read: if isAuthenticated() && (isSuperAdmin() || belongsToOrg(orgId));
        allow write: if isAuthenticated() && (isSuperAdmin() || belongsToOrg(orgId));
      }
    }
    
    match /settings/global {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    match /coupons/{couponId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }
  }
}
